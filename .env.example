# Copy this file to `.env` and fill in your form endpoint to get
# instant email notifications of every quote request.
#
# Easiest option (free, no server): create a form at https://formspree.io
# or https://web3forms.com and paste the endpoint URL below.
#
# If you leave this blank, the contact form still works — it falls back to
# opening a pre-filled email to the address in src/config.js.

VITE_FORM_ENDPOINT=

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). Create a free GA4
# property at https://analytics.google.com, then paste the ID here. Leave blank
# to keep GA4 off. (Vercel Web Analytics works separately and needs no ID.)
VITE_GA_ID=
